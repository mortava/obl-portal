# Copy to .env.local for local dev, or set these in Vercel → Project →
# Settings → Environment Variables for production.
#
# NEVER commit real secrets to git. .env.local is gitignored.
# In Vercel, mark every ENCOMPASS_* var as a Secret.

# ── Encompass / EDC ─────────────────────────────────────────────────────────
ENCOMPASS_ENV=sandbox                       # "sandbox" or "production"
ENCOMPASS_GRANT_TYPE=client_credentials     # "client_credentials" or "password"
ENCOMPASS_CLIENT_ID=                        # from EDC admin console
ENCOMPASS_CLIENT_SECRET=                    # from EDC admin console

# Required only for the password grant:
ENCOMPASS_INSTANCE_ID=                      # e.g. BE11111111
ENCOMPASS_API_USER=                         # e.g. apiuser (NOT a personal admin login)
ENCOMPASS_API_PASSWORD=                     # API user password

# Optional overrides — leave blank to use the defaults wired in the adapter:
ENCOMPASS_SCOPE=
ENCOMPASS_API_BASE_URL=
ENCOMPASS_OAUTH_BASE_URL=

# ── Anthropic (used by ai.* workflow steps; not exercised yet) ──────────────
ANTHROPIC_API_KEY=

# ── Supabase Auth ───────────────────────────────────────────────────────────
# Used by @supabase/ssr for cookie-based auth. Safe to ship to the browser —
# both values are public client-side identifiers (the URL and the publishable
# "anon" key). The actual service role key never appears in this repo.
NEXT_PUBLIC_SUPABASE_URL=https://vxoqwyntwsszipabhiuv.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_…

# ── Email via Microsoft Graph (Azure AD client credentials) ─────────────────
# The Azure AD app needs the *Application* (not Delegated) Mail.Send permission
# plus admin consent. AZURE_MAIL_FROM must be a real mailbox in the same tenant.
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=
AZURE_TENANT_ID=
AZURE_MAIL_FROM=

# ── Demo data flag ──────────────────────────────────────────────────────────
# When true, lib/data/*.ts falls back to in-memory samples on empty/erroring
# reads so the platform UI never goes blank. Toggle to false in production
# once real data is flowing into obl_* tables.
OBL_USE_SAMPLE_DATA=true
