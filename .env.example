# Copy to .env.local for local dev, or set these in Vercel → Project →
# Settings → Environment Variables for production.
#
# NEVER commit real secrets to git. .env.local is gitignored.
# In Vercel, mark every ENCOMPASS_* var as a Secret.

# ── Encompass / EDC ─────────────────────────────────────────────────────────
ENCOMPASS_ENV=sandbox                       # "sandbox" or "production"
ENCOMPASS_GRANT_TYPE=client_credentials     # "client_credentials" or "password"
ENCOMPASS_CLIENT_ID=                        # from EDC admin console
ENCOMPASS_CLIENT_SECRET=                    # from EDC admin console

# Required only for the password grant:
ENCOMPASS_INSTANCE_ID=                      # e.g. BE11111111
ENCOMPASS_API_USER=                         # e.g. apiuser (NOT a personal admin login)
ENCOMPASS_API_PASSWORD=                     # API user password

# Optional overrides — leave blank to use the defaults wired in the adapter:
ENCOMPASS_SCOPE=
ENCOMPASS_API_BASE_URL=
ENCOMPASS_OAUTH_BASE_URL=

# ── Anthropic (used by ai.* workflow steps; not exercised yet) ──────────────
ANTHROPIC_API_KEY=
